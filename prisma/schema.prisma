generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shop {
  id            Int       @id @default(autoincrement())
  domain        String    @unique
  accessToken   String
  isActive      Boolean   @default(true)
  uninstalledAt DateTime?
  ksefToken     String?
  ksefConnected Boolean   @default(false)
  ksefTestMode  Boolean   @default(true)
  sellerNip     String?
  sellerName    String?
  sellerAddress String?
  placeOfIssue  String?
  accountantEmail String?
  plan          String    @default("free")
  billingSubscriptionId String?
  billingStatus String?
  reviewDismissedAt DateTime?
  reviewRequestedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  invoices      KsefInvoice[]
  ksefSubmissions KsefSubmission[]
  orderFlags    OrderFlag[]
  buyerProfiles CustomerBuyerProfile[]
  sessions      ShopifySession[]
}

model ShopifySession {
  id          String   @id
  shopId      Int
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  state       String
  isOnline    Boolean  @default(false)
  scope       String
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shopId])
}

model OrderFlag {
  id          String   @id @default(uuid())
  shopId      Int
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  orderId     String
  orderName   String
  isB2b       Boolean  @default(false)
  nip         String?
  buyerName   String?
  buyerJst    Boolean  @default(false)
  buyerGv     Boolean  @default(false)
  processedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([shopId, orderId])
  @@index([shopId, isB2b, processedAt])
}

model CustomerBuyerProfile {
  id          String   @id @default(uuid())
  shopId      Int
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customerId  String
  nip         String
  buyerName   String?
  source      String   @default("manual")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([shopId, customerId])
  @@index([shopId, nip])
}

model KsefInvoice {
  id            String        @id @default(uuid())
  shopId        Int
  shop          Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  orderId       String
  orderName     String
  nip           String
  buyerName     String
  fa3Xml        String
  ksefNumber    String?
  ksefSessionRef String?
  status        String
  correctionOf  String?
  currency      String        @default("PLN")
  exchangeRate  Decimal?      @db.Decimal(14, 6)
  exchangeRateDate DateTime?
  exchangeRateTableNo String?
  totalGross    Decimal       @db.Decimal(12, 2)
  totalGrossPln Decimal?      @db.Decimal(12, 2)
  retryCount    Int           @default(0)
  nextRetryAt   DateTime?
  lastError     String?
  fa3ValidatedAt DateTime?
  fa3ValidationStatus String?
  fa3ValidationError String?
  upoXml        String?
  upoStatus     String?
  upoFetchedAt  DateTime?
  createdAt     DateTime      @default(now())
  submittedAt   DateTime?

  items         InvoiceItem[]
  submissions   KsefSubmission[]

  @@index([shopId, orderId])
  @@index([status, nextRetryAt])
  @@index([shopId, fa3ValidationStatus])
}

model NbpExchangeRate {
  id        String   @id @default(uuid())
  currency  String
  rateDate  DateTime
  tableNo   String
  rate      Decimal  @db.Decimal(14, 6)
  fetchedAt DateTime @default(now())

  @@unique([currency, rateDate])
}

model KsefSubmission {
  id                     String      @id @default(uuid())
  shopId                 Int
  shop                   Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  invoiceId              String
  invoice                KsefInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  mode                   String      @default("test")
  status                 String      @default("pending")
  sessionReferenceNumber String?
  invoiceReferenceNumber String?
  ksefNumber             String?
  attempts               Int         @default(0)
  nextRetryAt            DateTime?
  lastError              String?
  requestHash            String?
  responsePayload        Json?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  submittedAt            DateTime?

  @@index([shopId, status, nextRetryAt])
  @@index([invoiceId, createdAt])
}

model InvoiceItem {
  id          String      @id @default(uuid())
  invoiceId   String
  invoice     KsefInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  name        String
  quantity    Int
  unitPrice   Decimal     @db.Decimal(12, 2)
  vatRate     String
  totalNet    Decimal     @db.Decimal(12, 2)
  totalVat    Decimal     @db.Decimal(12, 2)
}
