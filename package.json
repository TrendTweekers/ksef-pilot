{
  "name": "ksef-pilot",
  "version": "0.1.0",
  "private": true,
  "description": "KSeF Pilot - Polish e-invoices for Shopify",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:web": "vite --host 0.0.0.0",
    "build": "npm run prisma:generate && tsc -p tsconfig.server.json && npm run copy:schemas && vite build",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json",
    "copy:schemas": "node -e \"require('fs').cpSync('src/server/schemas','dist/server/schemas',{recursive:true})\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@shopify/app-bridge": "^3.7.10",
    "@shopify/app-bridge-react": "^4.2.2",
    "@shopify/polaris": "^12.27.0",
    "@shopify/polaris-icons": "^8.11.1",
    "@vitejs/plugin-react": "^4.3.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "i18next": "^24.2.0",
    "i18next-browser-languagedetector": "^8.0.2",
    "jszip": "^3.10.1",
    "ksef-client-ts": "^0.9.0",
    "pdfkit": "^0.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.4.0",
    "xml-xsd-engine": "^1.7.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.6"
  },
  "engines": {
    "node": ">=20"
  }
}
