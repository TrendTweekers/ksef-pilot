NODE_ENV=development
PORT=3000
APP_URL=https://your-railway-domain.up.railway.app
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ksef_pilot
SHOPIFY_API_KEY=replace-me
VITE_SHOPIFY_API_KEY=replace-me
SHOPIFY_API_SECRET=replace-me
SHOPIFY_API_VERSION=2026-04
SHOPIFY_SCOPES=read_orders,read_customers,read_products
SHOPIFY_ORDER_SCAN_LIMIT=250
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=base64-encoded-32-byte-key
KSEF_ENVIRONMENT=TEST
KSEF_API_BASE_URL=
KSEF_LIVE_SUBMISSION_ENABLED=false
# Local DEMO/TEST smoke only. Never paste these into chat.
KSEF_TEST_TOKEN=
KSEF_TEST_NIP=5252763266
KSEF_SMOKE_SHOP_DOMAIN=smoke-ksef-submit.myshopify.com
KSEF_WORKER_SECRET=
KSEF_WORKER_AUTORUN=false
KSEF_WORKER_INTERVAL_SECONDS=300
KSEF_WORKER_BATCH_LIMIT=10
SHOPIFY_APP_HANDLE=ksef-pilot
# Optional exact Shopify Managed Pricing route.
# Use this if Shopify returns 404 for the default /charges/{app_handle}/pricing_plans URL.
# Tokens: {store}, {store_handle}, {shop}, {shop_domain}, {app_handle}
SHOPIFY_MANAGED_PRICING_URL_TEMPLATE=https://admin.shopify.com/store/{store}/charges/{app_handle}/pricing_plans
SHOPIFY_REVIEW_URL=
SUPPORT_EMAIL=support@fakturaflow.pl
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
RESEND_API_KEY=
RESEND_FROM_EMAIL=KSeF Pilot <support@fakturaflow.pl>
